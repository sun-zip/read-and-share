<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 콘솔 Appender (기존 설정 그대로) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 파일 Appender 추가 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 현재 로그 파일 경로 지정 -->
        <file>logs/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 파일 이름에 연-월-일_시-분과 인덱스(%i)를 포함시키며, 10MB가 넘으면 롤링 -->
            <fileNamePattern>logs/app.%d{yyyy-MM-dd_HH-mm}.%i.log</fileNamePattern>
            <!-- 최대 파일 크기를 10MB로 설정 -->
            <maxFileSize>10MB</maxFileSize>
            <!-- 예를 들어, 최대 30일간의 로그 파일을 보관하도록 설정 -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Hibernate SQL 로그를 위한 로거 추가 -->
    <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </logger>

    <!-- Root Logger에 기본 어펜더 등록 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>

</configuration>
